{
  "name": "n8n-nodes-walkme",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for WalkMe Digital Adoption Platform providing 12 resources and 80+ operations for user provisioning, systems management, content management, analytics, segments, goals, multi-language support, and discovery apps. Includes webhook trigger support.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-walkme.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-walkme#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-walkme/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "n8n-node",
    "walkme",
    "digital-adoption",
    "dap",
    "user-provisioning",
    "automation",
    "enterprise",
    "training",
    "onboarding"
  ],
  "main": "dist/nodes/WalkMe/WalkMe.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WalkMeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WalkMe/WalkMe.node.js",
      "dist/nodes/WalkMe/WalkMeTrigger.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.27.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
