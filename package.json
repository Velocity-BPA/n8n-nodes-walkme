{
  "name": "@velocity-bpa/n8n-nodes-walkme",
  "version": "1.0.0",
  "description": "n8n community node for WalkMe",
  "license": "bsl-catalog",
  "homepage": "https://github.com/velocity-bpa/n8n-nodes-walkme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velocity-bpa/n8n-nodes-walkme.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WalkMeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WalkMe/WalkMe.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "n8n-workflow": "*",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}